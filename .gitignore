# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.pyc

# QGIS processing logs / drafts (temporary)
logs/
Drafts/
Versions/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# GeoPackage & QGIS style sidecars (generated)
*.gpkg
*.gpkg-shm
*.gpkg-wal
*.qml

# Processing temp files
processing_*/

# ZIP archives (distribution snapshots)
*.zip

# Node / npm (used for GitHub CLI tooling)
node_modules/
package.json
package-lock.json

# GitHub auto-generated templates (workflow files are tracked intentionally)
.github/ISSUE_TEMPLATE/
.github/PULL_REQUEST_TEMPLATE.md

# Token / credential stores
.tokensave/

# Scratch / debug directories
# Throwaway bits only — test scripts under tmp/ stay visible so they can be
# `git add`'d later if you decide to commit them.
tmp-*/
tmp/hld-test/screenshots/
tmp/hld-test/uvicorn*.log
tmp/hld-test/static.log
tmp/hld-test/vite-stack.log
tmp/patch_main_recovery_v*.py

# Runtime pipeline output scratch (UUID-keyed task dirs the API writes)
web/backend/outputs/

# Python virtual environments
venv/
.venv/
env/
.venv.bak/

# Windows / CMD redirection artifact (accidental `> nul`)
nul

# Runtime logs
*.log
